    "# Смотрим какие уникальные локации есть\n",
    "print(df['location'].value_counts().head(30))\n",
    "\n",
    "# Фильтруем только то, где есть 'Nha Trang' или названия районов Нячанга\n",
    "nhatrang_mask = df['location'].str.contains('Nha Trang|Vĩnh|Phước|Lộc Thọ|Xương Huân', case=False, na=False)\n",
    "df_nt = df[nhatrang_mask].copy()\n",
    "\n",
    "# Теперь считаем топ по отфильтрованным данным\n",
    "top_nt = df_nt.groupby('location')['price_million_vnd'].mean().sort_values(ascending=False).head(15)\n",
    "\n",
    "plt.figure(figsize=(12,8))\n",
    "sns.barplot(x=top_nt.values, y=top_nt.index, palette='mako')\n",
    "plt.title('Топ-15 районов Нячанга по средней цене', fontsize=16)\n",
    "plt.xlabel('Средняя цена, млн VND')\n",
    "plt.ylabel('')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
